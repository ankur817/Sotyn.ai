---
import { SITE } from "../config/site";
export interface Props { variant?: "dark" | "light" }
const { variant = "light" } = Astro.props;
const c = SITE.countdown;
---
{c.enabled && (
  <div class={`cd cd--${variant}`} data-countdown data-mode={c.mode} data-deadline={c.deadline}>
    <span class="cd__label">{c.label}</span>
    <div class="cd__units">
      <div class="cd__u"><strong data-cd="d">00</strong><span>days</span></div>
      <div class="cd__sep" aria-hidden="true">:</div>
      <div class="cd__u"><strong data-cd="h">00</strong><span>hrs</span></div>
      <div class="cd__sep" aria-hidden="true">:</div>
      <div class="cd__u"><strong data-cd="m">00</strong><span>min</span></div>
      <div class="cd__sep" aria-hidden="true">:</div>
      <div class="cd__u"><strong data-cd="s">00</strong><span>sec</span></div>
    </div>
    {c.sublabel && <span class="cd__sub">{c.sublabel}</span>}
  </div>
)}

<style>
  .cd { text-align: center; }
  .cd__label {
    display: block;
    font-size: .76rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: 14px;
  }
  .cd__units {
    display: flex;
    gap: 6px;
    justify-content: center;
    align-items: center;
  }
  .cd__u {
    min-width: 64px;
    border-radius: var(--radius-sm);
    padding: 12px 8px;
    position: relative;
  }
  .cd__u strong {
    display: block;
    font-size: 1.9rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -.02em;
    font-variant-numeric: tabular-nums;
  }
  .cd__u span {
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    font-weight: 700;
    margin-top: 4px;
    display: block;
  }
  .cd__sep {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 14px;
  }
  .cd__sub {
    display: block;
    font-size: .78rem;
    margin-top: 14px;
    max-width: 400px;
    margin-inline: auto;
  }

  /* Dark variant */
  .cd--dark .cd__label { color: #94a3b8; }
  .cd--dark .cd__u {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    color: #fff;
  }
  .cd--dark .cd__u span { color: #94a3b8; }
  .cd--dark .cd__sep { color: rgba(255,255,255,.3); }
  .cd--dark .cd__sub { color: #94a3b8; }

  /* Light variant */
  .cd--light .cd__label { color: var(--brand-700); }
  .cd--light .cd__u {
    background: var(--brand-50);
    border: 1px solid var(--brand-100);
    color: var(--brand-800);
  }
  .cd--light .cd__u span { color: var(--muted); }
  .cd--light .cd__sep { color: var(--brand-200); }
  .cd--light .cd__sub { color: var(--muted); }
</style>

<script>
  function endOfMonth(offset = 0) {
    const n = new Date();
    return new Date(n.getFullYear(), n.getMonth() + 1 + offset, 0, 23, 59, 59);
  }
  function targetFor(el: Element) {
    const dl = el.getAttribute("data-deadline");
    if (dl) { const t = new Date(dl); if (!isNaN(t.getTime())) return t; }
    let t = endOfMonth(0);
    if (t.getTime() < Date.now()) t = endOfMonth(1);
    return t;
  }
  const pad = (n: number) => String(n).padStart(2, "0");
  const els = Array.from(document.querySelectorAll<HTMLElement>("[data-countdown]"));
  if (els.length) {
    const targets = els.map(targetFor);
    const tick = () => {
      const now = Date.now();
      els.forEach((el, i) => {
        let diff = Math.max(0, targets[i].getTime() - now);
        const d = Math.floor(diff / 86400000); diff -= d * 86400000;
        const h = Math.floor(diff / 3600000); diff -= h * 3600000;
        const m = Math.floor(diff / 60000); diff -= m * 60000;
        const s = Math.floor(diff / 1000);
        const set = (k: string, v: number) => { const n = el.querySelector(`[data-cd="${k}"]`); if (n) n.textContent = pad(v); };
        set("d", d); set("h", h); set("m", m); set("s", s);
      });
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
