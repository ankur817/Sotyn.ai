---
import { SITE, waLink, telLink } from "../config/site";
import Icon from "./Icon.astro";
const year = 2026;
const certs = ["ISO 9001:2015", "MSME Registered", "GST Compliant", "Data Hosted in India"];
---
<footer class="ft">
  <!-- Gradient top border -->
  <div class="ft__gradient" aria-hidden="true"></div>

  <div class="container ft__in">
    <div class="ft__brand">
      <div class="ft__logo">
        <img src="/images/sotyn_logo_v2.png" alt="sotyn.ai Logo" class="ft__logo-img" />
      </div>
      <p class="ft__tag">{SITE.tagline}.</p>
      <p class="ft__by">By {SITE.parentCompany} — a live EPC company that runs its entire business on sotyn.ai.</p>
      <p class="ft__by">Android &amp; iOS apps — coming soon on Google Play and the App Store.</p>

      <!-- Trust badges -->
      <div class="ft__badges">
        {certs.map((c) => (
          <span class="ft__badge"><Icon name="shield" size={14} /> {c}</span>
        ))}
      </div>
    </div>

    <nav class="ft__col" aria-label="Product">
      <h4>Product</h4>
      <a href="/features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/about">About &amp; case study</a>
      <a href="/#problem">Why it pays</a>
      <a href={SITE.appUrl} rel="nofollow">Customer login</a>
    </nav>

    <nav class="ft__col" aria-label="Company">
      <h4>Talk to us</h4>
      <a href={telLink}>{SITE.phone}</a>
      <a href={waLink()} rel="nofollow">WhatsApp</a>
      <a href={`mailto:${SITE.emailFallback}`}>{SITE.emailFallback}</a>
      <a href="/demo">Book a demo</a>
    </nav>

    <div class="ft__col">
      <h4>Office</h4>
      <p class="ft__addr">{SITE.address.street},<br />{SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}<br />{SITE.address.countryName}</p>

      {(SITE.social.linkedin || SITE.social.instagram) && (
        <div class="ft__social">
          {SITE.social.linkedin && (
            <a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="ft__social-link">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
          {SITE.social.instagram && (
            <a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="ft__social-link">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Social proof line -->
  <div class="container ft__proof">
    <p>Trusted by <strong>300+</strong> EPC professionals daily across <strong>18+ states</strong> in India</p>
  </div>

  <div class="container ft__bar">
    <p>© {year} {SITE.name} · {SITE.parentCompany}. All rights reserved.</p>
    <p class="ft__made">🇮🇳 Proudly built in India</p>
  </div>
</footer>

<style>
  .ft {
    background: var(--graphite-900);
    color: #94a3b8;
    position: relative;
  }

  /* Gradient top separator */
  .ft__gradient {
    height: 2px;
    background: linear-gradient(90deg, var(--brand-700), var(--brand-500), var(--brand-700));
  }

  .ft__in {
    display: grid;
    grid-template-columns: 2.2fr 1fr 1fr 1fr;
    gap: 40px;
    padding: 64px 0 48px;
  }

  /* Brand column */
  .ft__logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ft__logo-img {
    height: 96px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1); /* Pure white silhouette for the dark footer */
  }
  .ft__tag { margin: 18px 0 8px; color: #cbd5e1; font-weight: 600; font-size: .95rem; }
  .ft__by { font-size: .9rem; line-height: 1.7; max-width: 360px; margin: 0; }

  /* Trust badges */
  .ft__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }
  .ft__badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: .75rem;
    font-weight: 600;
    color: #94a3b8;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .08);
    padding: 5px 10px;
    border-radius: 6px;
    letter-spacing: .01em;
  }
  .ft__badge :global(.ico) { color: var(--brand-400); width: 14px; height: 14px; }

  /* Nav columns */
  .ft__col h4 {
    color: #e5e7eb;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: 18px;
    font-weight: 700;
  }
  .ft__col a {
    display: flex;
    align-items: center;
    gap: 0;
    color: #94a3b8;
    padding: 7px 0;
    font-size: .94rem;
    transition: color .2s var(--ease), gap .2s var(--ease);
  }
  .ft__col a:hover {
    color: #fff;
    text-decoration: none;
  }
  .ft__addr { font-size: .92rem; line-height: 1.7; margin: 0; }

  /* Social icons */
  .ft__social {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
  .ft__social-link {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, .06);
    border: 1px solid rgba(255, 255, 255, .08);
    color: #94a3b8;
    transition: all .2s var(--ease);
  }
  .ft__social-link:hover {
    background: rgba(255, 255, 255, .1);
    color: #fff;
    text-decoration: none;
    transform: translateY(-2px);
  }

  /* Social proof line */
  .ft__proof {
    text-align: center;
    padding: 20px 0;
    border-top: 1px solid rgba(255, 255, 255, .06);
    border-bottom: 1px solid rgba(255, 255, 255, .06);
  }
  .ft__proof p {
    margin: 0;
    font-size: .88rem;
    color: #64748b;
    letter-spacing: .01em;
  }
  .ft__proof strong { color: #94a3b8; }

  /* Bottom bar */
  .ft__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 22px;
    padding-bottom: 28px;
    font-size: .84rem;
  }
  .ft__bar p { margin: 0; }

  /* Responsive */
  @media (max-width: 900px) {
    .ft__in { grid-template-columns: 1fr 1fr; gap: 36px; }
    .ft__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .ft__in { grid-template-columns: 1fr; }
    .ft__bar { flex-direction: column; text-align: center; }
  }
</style>
