  <script>
    const el = document.querySelector("[data-rotate]");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (el && el.parentElement && !reduce) {
      const wrap = el.parentElement;
      const lines = [
        "Right now, your phone runs you.",
        "You are the server — every PO, payment and DPR waits for you.",
        "Nobody can say today's margin. Not even the accountant.",
        "Forty groups. One brain — and it's yours.",
        "When you travel, the company slows down.",
      ];
      let i = 0;
      setInterval(() => {
        wrap.classList.add("is-fading");
        setTimeout(() => {
          i = (i + 1) % lines.length;
          el.textContent = lines[i];
          wrap.classList.remove("is-fading");
        }, 320);
      }, 2900);
    }

    // Hero creative slideshow
    const slidesBox = document.querySelector("[data-slides]");
    if (slidesBox) {
      const slides = [...slidesBox.querySelectorAll(".hero__slide")];
      const dots = [...document.querySelectorAll(".hero__dots button")];
      let cur = 0;
      const show = (i) => {
        slides[cur].classList.remove("is-active");
        dots[cur]?.classList.remove("is-active");
        cur = i;
        slides[cur].classList.add("is-active");
        dots[cur]?.classList.add("is-active");
      };
      dots.forEach((d, i) => d.addEventListener("click", () => show(i)));
      if (!reduce) setInterval(() => show((cur + 1) % slides.length), 4500);
    }
  </script>
