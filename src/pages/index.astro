  .strip p { margin: 0; font-size: 1.05rem; }
  .strip__big {
    font-size: clamp(1.3rem, 2.8vw, 1.7rem);
    color: #fff;
    font-weight: 700;
    margin-top: 6px;
  }
  .strip__big strong { color: var(--brand-400); }

  /* ════════════════════════════════════════════════════════════════
     SOUND FAMILIAR
     ════════════════════════════════════════════════════════════════ */
  .sf {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .sf__card {
    background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.01));
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    padding: 32px 40px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sf__card::before {
    content: '"';
    position: absolute;
    top: -20px;
    left: 20px;
    font-size: 160px;
    font-family: serif;
    color: rgba(255,255,255,0.03);
    line-height: 1;
    pointer-events: none;
    transition: color 0.4s var(--ease);
  }
  .sf__card:hover {
    transform: translateY(-6px) scale(1.01);
    background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
    border-color: rgba(255,255,255,0.2);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 0 1px rgba(37, 99, 235, 0.3);
  }
  .sf__card:hover::before {
    color: rgba(37, 99, 235, 0.15);
  }
  .sf__card p {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 1.35rem;
    font-weight: 500;
    color: #f8fafc;
    line-height: 1.45;
    letter-spacing: -0.01em;
  }
  /* Bento layout spans */
  .sf__card:nth-child(1) { grid-column: span 7; }
  .sf__card:nth-child(2) { grid-column: span 5; }
  .sf__card:nth-child(3) { grid-column: span 4; }
  .sf__card:nth-child(4) { grid-column: span 8; }
  .sf__card:nth-child(5) { grid-column: span 6; }
  .sf__card:nth-child(6) { grid-column: span 6; }
  
  @media (max-width: 900px) {
    .sf__card:nth-child(n) { grid-column: span 12; }
  }

  /* ════════════════════════════════════════════════════════════════
     4 LEAKS
     ════════════════════════════════════════════════════════════════ */
  .leaks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
    text-align: left;
  }
  @media (max-width: 1024px) {
    .leaks-grid {
      grid-template-columns: 1fr;
    }
  }
  .leak-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 24px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .leak-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--brand-300);
  }
  .leak-card__header {
    background: var(--bg-alt);
    padding: 32px;
    border-bottom: 1px solid var(--line);
  }
  .leak-card__icon {
    width: 56px;
    height: 56px;
    background: var(--brand-600);
    color: #fff;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
  }
  .leak-card h3 {
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  .leak-card__body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    flex: 1;
  }
  .leak-card__problem, .leak-card__solution {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .leak-card__problem p, .leak-card__solution p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .leak-card__problem p { color: var(--body); }
  .leak-card__solution p { color: var(--ink); font-weight: 500; }
  
  .label {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: max-content;
  }
  .label--red { background: #fee2e2; color: #b91c1c; }
  .label--blue { background: var(--brand-50); color: var(--brand-700); }
  
  .leak-card__footer {
    padding: 24px 32px;
    background: var(--bg-surface);
    border-top: 1px solid var(--line);
  }
  .leak-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .leak-card__tags .tag {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    padding: 8px 14px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--body);
    box-shadow: var(--shadow-xs);
    transition: all 0.2s;
  }
  .leak-card:hover .tag {
    border-color: var(--brand-200);
    color: var(--brand-700);
  }

  /* ════════════════════════════════════════════════════════════════
     THESIS
     ════════════════════════════════════════════════════════════════ */
  .thesis {
    background: linear-gradient(135deg, var(--brand-700), var(--brand-600));
    color: #fff;
    padding: clamp(64px, 9vw, 110px) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .thesis::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(255,255,255,.06) 0%, transparent 50%),
      radial-gradient(circle at 80% 50%, rgba(255,255,255,.04) 0%, transparent 50%);
  }
  .thesis h2 {
    color: #fff;
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    max-width: 920px;
    margin: 0 auto 16px;
    letter-spacing: -.035em;
    line-height: 1.1;
    position: relative;
  }
  .thesis .hl-w { color: #bfdbfe; }
  .thesis p {
    color: #dbe4ff;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    max-width: 680px;
    margin: 0 auto;
    position: relative;
  }

  /* ════════════════════════════════════════════════════════════════
     BEFORE / AFTER
     ════════════════════════════════════════════════════════════════ */
  .ba__frame {
    max-width: 1060px;
    margin: 40px auto 0;
  }

  /* ════════════════════════════════════════════════════════════════
     PROOF
     ════════════════════════════════════════════════════════════════ */
  .proof {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .proof__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .proof__stat {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius);
    padding: 28px;
    transition: all var(--duration) var(--ease);
  }
  .proof__stat:hover {
    background: rgba(255,255,255,.07);
    transform: translateY(-2px);
  }
  .proof__stat strong {
    display: block;
    font-size: 2.1rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -.03em;
    line-height: 1;
  }
  .proof__stat span { font-size: .85rem; color: #94a3b8; margin-top: 6px; display: block; }

  /* ════════════════════════════════════════════════════════════════
     FOUNDER STRIP
     ════════════════════════════════════════════════════════════════ */
  .fstrip {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: center;
    max-width: 1020px;
    margin-inline: auto;
  }
  .fstrip__visual { position: relative; }
  .fstrip__photo {
    width: 200px;
    height: 240px;
    object-fit: cover;
    object-position: top center;
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
    border: 3px solid rgba(37, 99, 235, .15);
  }
  .fstrip__badges {
    display: flex;
    gap: 6px;
    margin-top: 12px;
    justify-content: center;
  }
  .fstrip__badge {
    font-size: .7rem;
    font-weight: 700;
    color: var(--brand-700);
    background: var(--brand-50);
    border: 1px solid var(--brand-100);
    padding: 4px 10px;
    border-radius: 6px;
    letter-spacing: .02em;
  }
  .fstrip__copy h2 { font-size: clamp(1.6rem, 3vw, 2.1rem); margin: 10px 0 14px; }
  .fstrip__copy .lead { margin-bottom: 0; }
  @media (max-width: 760px) {
    .fstrip { grid-template-columns: 1fr; text-align: center; justify-items: center; }
  }

  /* ════════════════════════════════════════════════════════════════
     BOOKS
     ════════════════════════════════════════════════════════════════ */
  .author {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 20px 8px 8px;
    box-shadow: var(--shadow-sm);
  }
  .author__photo {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    flex: none;
  }
  .author__txt {
    display: flex;
    flex-direction: column;
    text-align: left;
    line-height: 1.25;
  }
  .author__txt strong { color: var(--ink); font-size: .95rem; }
  .author__txt span { color: var(--muted); font-size: .82rem; }

  .books { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .book {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 28px;
    align-items: center;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 28px;
    box-shadow: var(--shadow-sm);
    transition: all .3s var(--ease);
  }
  .book:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
    border-color: var(--graphite-300);
  }
  .book__cover {
    width: 140px;
    height: 196px;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: var(--shadow);
    flex: none;
    transition: transform .3s var(--ease);
  }
  .book:hover .book__cover { transform: rotate(-2deg) scale(1.03); }
  .book__body h3 { font-size: 1.15rem; margin: 14px 0 8px; }
  .book__body p { font-size: .93rem; color: var(--muted); margin-bottom: 14px; }
  .book__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    font-size: .92rem;
    color: var(--brand-700);
    transition: gap .2s var(--ease);
  }
  .book__link:hover { gap: 10px; text-decoration: none; }
  .book__link--muted { color: var(--muted); }

  /* ════════════════════════════════════════════════════════════════
     LEAD MAGNET BAND
     ════════════════════════════════════════════════════════════════ */
  .magnetband {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .magnetband__copy h2 { margin-bottom: 14px; }
  .magnetband__tie { margin: 22px 0 0; font-size: .92rem; color: var(--muted); }
  @media (max-width: 920px) { .magnetband { grid-template-columns: 1fr; gap: 36px; } }

  /* ════════════════════════════════════════════════════════════════
     AI-FIRST
     ════════════════════════════════════════════════════════════════ */
  .ai__hl { color: var(--brand-400); }
  .ai__card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius);
    padding: 28px;
    transition: all .3s var(--ease);
    position: relative;
  }
  .ai__card:hover {
    background: rgba(255,255,255,.07);
    border-color: rgba(255,255,255,.14);
    transform: translateY(-4px);
  }
  .ai__badge-wrap {
    position: absolute;
    top: 16px;
    right: 16px;
  }
  .ai__ic {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--brand-600), var(--brand-500));
    color: #fff;
    display: grid;
    place-items: center;
    margin-bottom: 16px;
    box-shadow: 0 4px 12px rgba(37, 99, 235, .3);
  }
  .ai__card h3 { color: #fff; margin-bottom: 8px; font-size: 1.12rem; }
  .ai__card p { color: #94a3b8; font-size: .94rem; margin: 0; line-height: 1.6; }

  /* ════════════════════════════════════════════════════════════════
     FIELD / MOBILE
     ════════════════════════════════════════════════════════════════ */
  .field__in {
    display: grid;
    grid-template-columns: .85fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .field__device {
    position: relative;
    width: 280px;
    margin: 0 auto;
    background: var(--graphite-900);
    border-radius: 36px;
    padding: 12px;
    box-shadow: var(--shadow-xl);
    border: 2px solid rgba(255, 255, 255, .08);
  }
  .field__notch {
    width: 120px;
    height: 26px;
    background: var(--graphite-900);
    border-radius: 0 0 16px 16px;
    margin: -12px auto 8px;
    position: relative;
    z-index: 1;
  }
  .field__img {
    width: 100%;
    height: auto;
    border-radius: 24px;
    display: block;
  }
  @media (max-width: 860px) {
    .field__in { grid-template-columns: 1fr; }
    .field__device { width: 240px; }
  }

  /* ════════════════════════════════════════════════════════════════
     MODULES
     ════════════════════════════════════════════════════════════════ */
  .mod__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }
  .mod__icon {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--brand-50);
    color: var(--brand-700);
    display: grid;
    place-items: center;
    flex: none;
    transition: all var(--duration) var(--ease);
  }
  .card:hover .mod__icon {
    background: linear-gradient(135deg, var(--brand-600), var(--brand-500));
    color: #fff;
  }
  .mod__head h3 { margin: 0; }
  .mod__list { list-style: none; display: grid; gap: 10px; }
  .mod__list li {
    position: relative;
    padding-left: 20px;
    font-size: .94rem;
    color: var(--body);
  }
  .mod__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 9px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--brand-500);
    transition: transform var(--duration) var(--ease);
  }
  .card:hover .mod__list li::before { transform: scale(1.4); }

  /* ════════════════════════════════════════════════════════════════
     INDIA / DATA RESIDENCY
     ════════════════════════════════════════════════════════════════ */
  .india__in {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .india__copy h2 { margin-bottom: 16px; }
  .creds { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .cred {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: .88rem;
    font-weight: 600;
    color: var(--graphite-700);
    background: var(--graphite-100);
    border: 1px solid var(--line);
    padding: 8px 14px;
    border-radius: 999px;
    transition: all var(--duration) var(--ease);
  }
  .cred:hover { background: var(--brand-50); border-color: var(--brand-100); }
  .cred :global(.ico) { color: var(--brand-600); }
  .india__pillars { display: grid; gap: 16px; }
  .pillar {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px 28px;
    box-shadow: var(--shadow-sm);
    transition: all var(--duration) var(--ease);
  }
  .pillar:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }
  .pillar :global(.ico) { color: var(--brand-600); margin-bottom: 10px; }
  .pillar h3 { font-size: 1.12rem; margin-bottom: 6px; }
  .pillar p { margin: 0; font-size: .94rem; color: var(--muted); }

  /* ════════════════════════════════════════════════════════════════
     STEPS / HOW IT WORKS
     ════════════════════════════════════════════════════════════════ */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    position: relative;
  }
  .step {
    position: relative;
    text-align: center;
    padding: 0 8px;
  }
  .step__n {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    font-weight: 900;
    color: #fff;
    background: linear-gradient(135deg, var(--brand-600), var(--brand-500));
    margin: 0 auto 18px;
    font-size: 1.1rem;
    box-shadow: var(--shadow-brand);
    position: relative;
    z-index: 1;
  }
  .step h3 { margin-bottom: 10px; }
  /* Connector line between steps */
  .step__line {
    position: absolute;
    top: 24px;
    left: calc(50% + 28px);
    width: calc(100% - 56px);
    height: 2px;
    background: linear-gradient(90deg, var(--brand-200), var(--brand-100));
    z-index: 0;
  }
  .step:last-child .step__line { display: none; }
  @media (max-width: 940px) {
    .steps { grid-template-columns: repeat(2, 1fr); }
    .step__line { display: none; }
  }
  @media (max-width: 640px) {
    .steps { grid-template-columns: 1fr; }
  }

  /* ════════════════════════════════════════════════════════════════
     TRUST NUMBERS
     ════════════════════════════════════════════════════════════════ */
  .nums { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .num {
    text-align: center;
    padding: 28px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius);
    transition: all var(--duration) var(--ease);
  }
  .num:hover {
    background: rgba(255,255,255,.07);
    transform: translateY(-3px);
  }
  .num strong {
    display: block;
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -.03em;
    line-height: 1;
  }
  .num span { display: block; font-size: .82rem; color: #94a3b8; margin-top: 10px; }
  @media (max-width: 760px) { .nums { grid-template-columns: repeat(2, 1fr); } }

  /* ════════════════════════════════════════════════════════════════
     CAPABILITIES
     ════════════════════════════════════════════════════════════════ */
  .cap {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px;
    box-shadow: var(--shadow-sm);
    transition: all var(--duration) var(--ease);
  }
  .cap:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }
  .cap__ic {
    width: 50px;
    height: 50px;
    border-radius: 13px;
    background: var(--brand-50);
    color: var(--brand-700);
    display: grid;
    place-items: center;
    margin-bottom: 16px;
    transition: all var(--duration) var(--ease);
  }
  .cap:hover .cap__ic {
    background: linear-gradient(135deg, var(--brand-600), var(--brand-500));
    color: #fff;
  }
  .cap h3 { font-size: 1.12rem; margin-bottom: 8px; }
  .cap p { font-size: .95rem; margin: 0; }
  .certs2 {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 36px;
  }
  .cert2 {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: .88rem;
    font-weight: 600;
    color: var(--graphite-700);
    background: var(--graphite-100);
    border: 1px solid var(--line);
    padding: 8px 14px;
    border-radius: 999px;
  }
  .cert2 :global(.ico) { color: var(--brand-600); }

  /* ════════════════════════════════════════════════════════════════
     TESTIMONIALS
     ════════════════════════════════════════════════════════════════ */
  .tcard {
    position: relative;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 32px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: all var(--duration) var(--ease);
  }
  .tcard:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }
  .tcard__q {
    font-size: 4rem;
    line-height: .8;
    color: var(--brand-100);
    font-weight: 900;
    font-family: Georgia, serif;
    margin-bottom: 8px;
  }
  .tcard blockquote {
    margin: 0 0 20px;
    font-size: 1.04rem;
    color: var(--ink);
    line-height: 1.55;
