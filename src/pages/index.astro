---
import BaseLayout from "../layouts/BaseLayout.astro";
import DemoForm from "../components/DemoForm.astro";
import BookLeadMagnet from "../components/BookLeadMagnet.astro";
import Icon from "../components/Icon.astro";
import SectionDiagram from "../components/SectionDiagram.astro";
import CreativeCard from "../components/CreativeCard.astro";
import { SITE, waLink } from "../config/site";

// ── WHO THIS IS FOR ─────────────────────────────────────────────────────────
const audience = [
  {
    icon: "building",
    t: "A ₹5–100 Cr MEPF, EPC or solar firm",
    d: "Multiple live sites, one head office, and a team that grew faster than your systems.",
  },
  {
    icon: "phone",
    t: "Every decision routes through you",
    d: "Approvals live on calls and WhatsApp. When you travel, the company slows down.",
  },
  {
    icon: "refresh",
    t: "No appetite for a 2-year ERP project",
    d: "You need it working in weeks — and used by site engineers, not just the office.",
  },
];

// ── THE PROBLEM — lost between the systems ──────────────────────────────────
const problem = [
  { n: "3", unit: "parallel systems", d: "WhatsApp + Excel + memory. None of them agree with each other." },
  { n: "0", unit: "sources of truth", d: "Nobody can say today’s margin on any live project — including the accountant." },
  { n: "You", unit: "the human ERP", d: "Every PO, payment and DPR waits for your phone. You are the server." },
];

// ── YOUR THREE OPTIONS TODAY ─────────────────────────────────────────────────
const options = [
  {
    icon: "box",
    t: "A big ERP",
    sub: "SAP / Oracle",
    good: "Real system, real discipline.",
    bad: "But built for manufacturers. ₹50L+ and 18 months in, your site engineers still won’t open it.",
  },
  {
    icon: "layers",
    t: "A stack of apps",
    sub: "Tally + Zoho + 5 tools",
    good: "Cheap and quick to start.",
    bad: "But nothing talks to anything. You become the integration between your own software.",
  },
  {
    icon: "users",
    t: "More managers + more Excel",
    sub: "No new software",
    good: "Familiar. Nothing to learn.",
    bad: "But you’re adding salary to manage confusion — and the truth still lives in five versions of one sheet.",
  },
];

// ── IMAGINE THE PERFECT SYSTEM ──────────────────────────────────────────────
const imagine = [
  { icon: "building", t: "Built around site reality", d: "DPRs, BOQs, POs, labour attendance — not manufacturing modules renamed for you." },
  { icon: "phone", t: "Runs on phones your staff already carry", d: "If a supervisor can use WhatsApp, he can file a DPR." },
  { icon: "lock", t: "Every approval ticketed", d: "No ticket, no work. No verbal decisions. Every action time-stamped and owned." },
  { icon: "gauge", t: "Scores every employee weekly", d: "Performance visible on one screen. Politics and “I told him verbally” — gone." },
  { icon: "bolt", t: "AI does the data entry", d: "Reports write themselves. Your engineers engineer." },
];

// ── THREE COMMITMENTS, IN WRITING ───────────────────────────────────────────
const commitments = [
  {
    n: "01",
    t: "Every module a contractor needs",
    d: "Projects & DPRs, estimation & BOQ, procurement & POs, finance & receivables, HR & compliance — one system, one login.",
  },
  {
    n: "02",
    t: "Your time back",
    d: "Stop refereeing WhatsApp groups. Review one dashboard, 30 minutes a day. Approvals move without your phone.",
  },
  {
    n: "03",
    t: "A scorecard culture that sticks",
    d: "Every employee gets KRAs, KPIs and a weekly score. ERPs fail when people dodge them — the scorecard makes usage non-negotiable.",
  },
];

// ── WHAT'S INSIDE — every workflow a contractor runs ────────────────────────
const inside = [
  { icon: "building", t: "Projects & milestones", d: "owner, margin, plan vs actual" },
  { icon: "hardhat", t: "Site DPRs & photos", d: "daily, from every site" },
  { icon: "target", t: "Estimation & BOQ", d: "bid-vs-actual variance" },
  { icon: "box", t: "Procurement & POs", d: "zero parallel manual POs" },
  { icon: "trending-up", t: "Sales pipeline", d: "₹ by stage, next action" },
  { icon: "wallet", t: "Finance & receivables", d: "DSO, aged receivables, project P&L" },
  { icon: "users", t: "Attendance & labour", d: "site-wise, productivity index" },
  { icon: "gauge", t: "KRA / KPI scorecard", d: "weekly score for 100% of staff" },
  { icon: "shield", t: "Compliance RAG", d: "GST, TDS, PF, ESI status", soon: true },
];

// ── THE SCORECARD — the part no ERP touches ─────────────────────────────────
const scoreBands = [
  { r: "9–10", t: "Role model" },
  { r: "7–8", t: "Reliable" },
  { r: "5–6", t: "Improve" },
  { r: "<5", t: "Risk" },
];

// ── HOW WE WORK — audit to go-live, 30 days ─────────────────────────────────
const how = [
  { n: "1", t: "Audit", d: "We map your workflows, projects, people and leakage points. One week, on your sites." },
  { n: "2", t: "Configure & migrate", d: "Your live projects, BOQs, vendors and team loaded into sotyn.ai." },
  { n: "3", t: "Train", d: "Scorecard training for 100% of staff — on live screens of your data. No mockups." },
  { n: "4", t: "Go live", d: "Weekly reviews running. Approvals ticketed. WhatsApp-and-Excel operations retired." },
];

// ── OUR ASK — the 30-day pilot ──────────────────────────────────────────────
const pilot = [
  "Workflow & leakage audit of your current operation",
  "sotyn.ai configured with your live projects, BOQs and vendors",
  "KRAs, KPIs and weekly scorecards installed for every employee",
  "Your team trained on live screens of your own data",
  "First weekly review cycle running before we leave",
];

// Real names the parent EPC company has delivered for (social proof, per deck).
const clients = ["Airtel", "Luminous", "V-Guard", "Indian Army", "Dabur", "Fortis", "Hyatt"];

// Credentials (real, from the company profile).
const creds = ["14+ years in business", "ISO 9001:2015", "MSME certified", "18+ states", "300+ users daily"];

// 11 languages — English + the top-10 Indian languages (2011 Census figures).
const languages = [
  { native: "English", name: "English", speakers: "the default" },
  { native: "हिन्दी", name: "Hindi", speakers: "52.8 Cr speakers" },
  { native: "বাংলা", name: "Bengali", speakers: "9.7 Cr speakers" },
  { native: "मराठी", name: "Marathi", speakers: "8.3 Cr speakers" },
  { native: "తెలుగు", name: "Telugu", speakers: "8.1 Cr speakers" },
  { native: "தமிழ்", name: "Tamil", speakers: "6.9 Cr speakers" },
  { native: "ગુજરાતી", name: "Gujarati", speakers: "5.5 Cr speakers" },
  { native: "اردو", name: "Urdu", speakers: "5.1 Cr speakers" },
  { native: "ಕನ್ನಡ", name: "Kannada", speakers: "4.4 Cr speakers" },
  { native: "ଓଡ଼ିଆ", name: "Odia", speakers: "3.75 Cr speakers" },
  { native: "മലയാളം", name: "Malayalam", speakers: "3.48 Cr speakers" },
];

const faqs = [
  { q: "Isn’t this just another SAP or Oracle my site team won’t use?", a: "No. Big ERPs are built for manufacturers and take 18 months and ₹50L+ before anyone logs in. sotyn.ai is built around how a contracting site actually runs a day — DPRs, BOQs, POs, labour attendance — and runs on the phones your site staff already carry. If a supervisor can use WhatsApp, he can file a DPR." },
  { q: "What is the scorecard, and why does it matter?", a: "Software tracks the money; the scorecard moves the people. Every employee gets KRAs, KPIs and one weekly score — 20% for system discipline, 80% for real output. ERPs fail because people avoid them; when the weekly score lives in the system, using the system becomes the only way to be seen. Adoption stops being optional." },
  { q: "We already run on Tally and Excel. Do we throw them away?", a: "No. We migrate your existing masters, live projects, BOQs and vendors during setup, and sotyn.ai links with Tally — so you start with your real data, not a blank slate. What you retire is the WhatsApp-and-Excel guesswork, not your accounts." },
  { q: "My site staff don’t work in English. Will they actually use it?", a: "Yes — sotyn.ai is India’s first EPC ERP that runs in 11 languages: English plus Hindi, Bengali, Marathi, Telugu, Tamil, Gujarati, Urdu, Kannada, Odia and Malayalam. Together that’s the mother tongue of roughly 90% of India — so a supervisor files his DPR in his own language, on his own phone." },
  { q: "How fast can we go live?", a: "30 days, not an 18-month ERP project. Four steps — audit, configure & migrate, train, go live — and your first weekly review cycle is running before we leave." },
  { q: "Is my data safe and separate?", a: "Yes. Each company runs in its own secure workspace, hosted in India, with role-based access and a full audit log — every action time-stamped and owned. Your data is yours, never sold and never shared with another contractor." },
];

const faqSchema = [{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
}];

// Organization schema — brand entity for Google & AI answer engines.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  legalName: SITE.parentCompany,
  url: SITE.url,
  logo: `${SITE.url}/favicon.svg`,
  slogan: SITE.motto,
  telephone: SITE.phone,
  email: SITE.emailFallback,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.region,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  sameAs: [SITE.social.linkedin, SITE.social.instagram].filter(Boolean),
};
---
<BaseLayout
  title="EPC ERP Software for Contractors in India — sotyn.ai | Contracting without the chaos"
  description="The EPC ERP built inside a 535+ project contracting company — projects, procurement, billing, payroll & weekly scorecards in one login, in 11 languages. Live in 30 days. If it’s not in SOTYN, it didn’t happen."
  schema={[...faqSchema, orgSchema]}
>
  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero__top">
        <div class="hero__copy">
          <span class="pill"><Icon name="bolt" size={15} /> The ERP built inside a contracting company — not a software lab</span>
          <h1>Contracting without <span class="hl">the chaos</span>.</h1>
          <p class="hero__rotator" aria-live="polite"><span data-rotate>Right now, your phone runs you.</span></p>
          <p class="lead">
            One system runs your projects, procurement, cash and people — built and battle-tested
            inside <strong>{SITE.parentCompany}</strong>, a 535+ project MEPF &amp; Solar EPC company.
            Not software a lab imagined for you. Software <strong>a contractor runs their own company on</strong>.
          </p>
          <div class="btn-row">
            <a href="#pilot" class="btn btn--primary btn--lg">Commission your 30-day pilot</a>
            <a href="#problem" class="btn btn--ghost btn--lg">See where the margin goes</a>
          </div>
        </div>
        <figure class="hero__media" aria-label="sotyn.ai campaign creatives">
          <div class="hero__slides" data-slides>
            <div class="hero__slide is-active"><CreativeCard variant="groups" /></div>
            <div class="hero__slide"><CreativeCard variant="phone" /></div>
            <div class="hero__slide"><CreativeCard variant="proof" /></div>
          </div>
          <div class="hero__dots">
            <button class="is-active" aria-label="Show creative 1"></button>
            <button aria-label="Show creative 2"></button>
            <button aria-label="Show creative 3"></button>
          </div>
        </figure>
      </div>
      <div class="hero__stats">
        {SITE.stats.map((s) => (
          <div class="hero__stat"><strong>{s.value}</strong><span>{s.label}</span></div>
        ))}
      </div>
      <p class="hero__by">By <strong>{SITE.parentCompany}</strong> · 535+ projects of contracting DNA · 14+ years · 18+ states — you’re buying software a contractor trusts with their own money.</p>
    </div>
  </section>

  <!-- ── WHO THIS IS FOR ──────────────────────────────────────────────── -->
  <section class="section" id="who">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Who this is for</span>
        <h2>You run a contracting business. Right now, your phone runs you.</h2>
        <p class="lead" style="margin-inline:auto">If two of these three describe your day, the rest of this page is written for you.</p>
      </div>
      <div class="verts">
        {audience.map((a) => (
          <div class="vert">
            <div class="vert__ic"><Icon name={a.icon} size={22} /></div>
            <h3>{a.t}</h3>
            <p>{a.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── AD CREATIVES (campaign hooks) ────────────────────────────────── -->
  <section class="section" id="creatives">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">The campaign</span>
        <h2>Three hooks. One message.</h2>
        <p class="lead" style="margin-inline:auto">The exact creatives we run — which one stops your scroll?</p>
      </div>
      <div class="cr-grid">
        <a class="crlink" href="#pilot" aria-label="Get out of the groups — commission your 30-day pilot"><CreativeCard variant="groups" /></a>
        <a class="crlink" href="#pilot" aria-label="Stop being the server — commission your 30-day pilot"><CreativeCard variant="phone" /></a>
        <a class="crlink" href="#pilot" aria-label="We run our company on it — commission your 30-day pilot"><CreativeCard variant="proof" /></a>
      </div>
    </div>
  </section>

  <!-- ── PRODUCT SHOWCASE (one login, live) ───────────────────────────── -->
  <section class="showcase section--alt">
    <div class="container text-center">
      <span class="eyebrow">One login. Every project, every rupee, every person. Live.</span>
      <h2>This is what “one source of truth” looks like.</h2>
      <p class="lead" style="margin-inline:auto">Margin, cash, receivables and every site — live, on one screen. No more year-end surprises.</p>
      <img class="showcase__img" src="/images/hero-dashboard.png" alt="sotyn.ai control tower showing margin, cash, receivables and live site status" width="1280" height="820" loading="lazy" />
    </div>
  </section>

  <!-- ── THE PROBLEM — between the systems ────────────────────────────── -->
  <section class="section section--dark" id="problem">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">The problem</span>
        <h2 style="color:#fff">Contractors don’t lose margin on site.<br />They lose it <span class="ai__hl">between the systems</span>.</h2>
      </div>
      <div class="probs">
        {problem.map((p) => (
          <div class="prob">
            <strong>{p.n}</strong>
            <span class="prob__u">{p.unit}</span>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
      <SectionDiagram name="problem" />
      <p class="probs__foot">Delayed POs, missed receivables, silent cost overruns — found months later, at year-end, when nothing can be done.</p>
    </div>
  </section>

  <!-- ── FORTY GROUPS. ONE BRAIN. (big hook) ──────────────────────────── -->
  <section class="thesis">
    <div class="container">
      <h2>Forty groups. One brain —<br />and it’s <span class="hl-w">yours</span>.</h2>
      <p>Sales in one group, site photos in another, POs on phone calls, cash in an Excel only you open. Every person is working. The company still crawls — because the only place it all comes together is your head.</p>
    </div>
  </section>

  <!-- ── SOUND FAMILIAR (hooks, deck voice) ───────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Sound familiar?</span>
        <h2>If you’ve said any of these, it isn’t bad luck. It’s the gap between your systems.</h2>
      </div>
      <div class="sf">
        <div class="sf__card"><p><span class="sf__q">“</span>You are the server. Everything waits for my phone.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>Nobody can tell me today’s margin on a live project.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>When I travel, the whole company slows down.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>The truth lives in five versions of one sheet.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>I’m adding managers just to manage the confusion.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>If it wasn’t on a call, ‘I told him verbally’ is all I’ve got.<span class="sf__q">”</span></p></div>
      </div>
    </div>
  </section>

  <!-- ── YOUR THREE OPTIONS TODAY ─────────────────────────────────────── -->
  <section class="section section--alt" id="options">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Your three options today</span>
        <h2>Every route leaves the same gap.</h2>
        <p class="lead" style="margin-inline:auto">You’ve looked at all three. Here’s why each one still leaves you as the integration.</p>
      </div>
      <div class="opts">
        {options.map((o) => (
          <article class="opt">
            <div class="opt__ic" aria-hidden="true"><Icon name={o.icon} size={26} /></div>
            <h3>{o.t}</h3>
            <span class="opt__sub">{o.sub}</span>
            <p class="opt__good">{o.good}</p>
            <p class="opt__bad">{o.bad}</p>
          </article>
        ))}
      </div>
      <SectionDiagram name="options" />
      <p class="text-center opts__foot">No system is built around how a contracting site actually runs a day. So we built one.</p>
    </div>
  </section>

  <!-- ── IMAGINE THE PERFECT SYSTEM ───────────────────────────────────── -->
  <section class="section" id="imagine">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Imagine the perfect system</span>
        <h2>What would it take to get your evenings back?</h2>
        <p class="lead" style="margin-inline:auto">Five things no renamed manufacturing ERP will ever give you — and every one is how sotyn.ai was built.</p>
      </div>
      <div class="imag">
        {imagine.map((i) => (
          <div class="imag__card">
            <div class="imag__ic"><Icon name={i.icon} size={22} /></div>
            <div>
              <h3>{i.t}</h3>
              <p>{i.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── OUR PROMISE (band) ───────────────────────────────────────────── -->
  <section class="strip">
    <div class="container strip__in">
      <p>Projects. Procurement. Finance. People — one integrated system.</p>
      <p class="strip__big">“If it’s not in <strong>SOTYN</strong>, it didn’t happen.”</p>
    </div>
  </section>

  <!-- ── THREE COMMITMENTS, IN WRITING ────────────────────────────────── -->
  <section class="section section--alt" id="commitments">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Three commitments, in writing</span>
        <h2>Not features. Obligations.</h2>
      </div>
      <div class="grid grid-3 commits">
        {commitments.map((c) => (
          <div class="commit">
            <div class="commit__n">{c.n}</div>
            <h3>{c.t}</h3>
            <p>{c.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── THE PROOF — the demo is our real company ─────────────────────── -->
  <section class="section section--dark" id="proof">
    <div class="container proof">
      <div class="proof__copy">
        <span class="eyebrow">The proof</span>
        <h2>The demo is our real company.</h2>
        <p class="lead">
          Ask for any screen and we open our own live system — real projects, real POs, real
          weekly scores, running {SITE.parentCompany} today. No mockups. No staged data.
          No “imagine the dashboard.”
        </p>
        <ul class="check-list" style="margin-top:8px">
          <li>We didn’t build an ERP and go looking for a contractor</li>
          <li>We are the contractor — customer #1 is us</li>
          <li>The playbook it enforces is the playbook you get</li>
        </ul>
        <div class="btn-row" style="margin-top:26px">
          <a href="#demo" class="btn btn--white btn--lg">Ask to see any screen, live</a>
        </div>
      </div>
      <div class="proof__stats">
        {SITE.stats.map((s) => (
          <div class="proof__stat"><strong>{s.value}</strong><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── REAL SITES & TEAMS (real photos) ─────────────────────────────── -->
  <section class="section section--alt realworld">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">On the ground</span>
        <h2>Built for how Indian sites actually run.</h2>
        <p class="lead" style="margin-inline:auto">From the first site visit to the weekly office review — sotyn.ai is shaped around the real rhythm of a contracting business.</p>
      </div>
      <div class="rw__grid">
        <figure class="rw__photo">
          <img src="/images/real-site.jpg" alt="Two Indian MEP site engineers in hard hats and hi-vis vests inspecting overhead services on an under-construction site, one holding a tablet" loading="lazy" width="1200" height="1697" />
          <figcaption>On site — services checked against the plan, on a tablet.</figcaption>
        </figure>
        <figure class="rw__photo">
          <img src="/images/real-phone.jpg" alt="An Indian site supervisor in a hard hat and hi-vis vest checking the sotyn.ai app on his phone at a construction site" loading="lazy" width="1200" height="1697" />
          <figcaption>In the field — DPRs, attendance and snags from the phone in a worker’s pocket.</figcaption>
        </figure>
        <figure class="rw__photo">
          <img src="/images/real-team.jpg" alt="An Indian engineering team in hi-vis vests reviewing live project data together on a laptop in a site office" loading="lazy" width="1200" height="1697" />
          <figcaption>In the office — the weekly review, on live numbers.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── WHAT'S INSIDE ────────────────────────────────────────────────── -->
  <section class="section" id="inside">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">What’s inside</span>
        <h2>Every workflow a contractor runs. One system.</h2>
        <p class="lead" style="margin-inline:auto">No more parallel systems that don’t agree. Quote, procure, build, bill, collect and score — all in one place, talking to each other.</p>
      </div>
      <SectionDiagram name="inside" />
      <div class="inside">
        {inside.map((m) => (
          <div class="ins">
            <span class="ins__ic" aria-hidden="true"><Icon name={m.icon} size={22} /></span>
            <div>
              <h3>{m.t} {m.soon && <span class="soon">Coming soon</span>}</h3>
              <p>{m.d}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center muted" style="margin-top:28px">One login · role-based access · every action time-stamped and owned.</p>
    </div>
  </section>

  <!-- ── BUILT FOR THE FIELD (mobile) ─────────────────────────────────── -->
  <section class="section section--alt field">
    <div class="container field__in">
      <img class="field__img" src="/images/app-mobile.png" alt="sotyn.ai site app on a phone — daily report, attendance and snags" width="600" height="1080" loading="lazy" />
      <div class="field__copy">
        <span class="eyebrow">Runs on the phones your staff already carry</span>
        <h2>If a supervisor can use WhatsApp, he can file a DPR.</h2>
        <p class="lead">Your site team doesn’t open laptops. sotyn.ai is mobile-first and in plain language — so daily reports, attendance and snags actually get logged, from the site, the same day.</p>
        <ul class="check-list" style="margin-top:8px">
          <li>Daily progress reports in two taps</li>
          <li>Real attendance — no ghost labour</li>
          <li>Snags raised with a photo, on the spot</li>
          <li>Works on any phone, even low-end</li>
