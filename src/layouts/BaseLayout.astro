---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import ExitPopup from "../components/ExitPopup.astro";
import ScrollAnimations from "../components/ScrollAnimations.astro";
import { SITE } from "../config/site";

export interface Props {
  title: string;
  description: string;
  /** path only, e.g. "/features". Defaults to current. */
  path?: string;
  /** extra JSON-LD objects to inject */
  schema?: Record<string, any>[];
  ogImage?: string;
  noindex?: boolean;
}
const {
  title,
  description,
  path = Astro.url.pathname,
  schema = [],
  ogImage = "/og-image.png",
  noindex = false,
} = Astro.props;

const canonical = new URL(path, SITE.url).href.replace(/\/$/, "") || SITE.url;
const ogImageUrl = new URL(ogImage, SITE.url).href;

// ── Organization structured data (sitewide) — powers Google Knowledge + AI search ──
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.parentCompany,
  alternateName: SITE.name,
  url: SITE.url,
  logo: new URL("/images/sotyn_logo_v2.png", SITE.url).href,
  foundingDate: "2011",
  founder: { "@type": "Person", name: "Er. Ankur Kaplesh" },
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.region,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  areaServed: { "@type": "Country", name: "India" },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: `+${SITE.phoneHref}`,
    contactType: "sales",
    areaServed: "IN",
    availableLanguage: ["en", "hi"],
  },
  sameAs: [SITE.social.linkedin, SITE.social.instagram, SITE.social.twitter, SITE.social.youtube].filter(Boolean),
};

// ── SoftwareApplication — positioned as an AI construction platform, not "ERP" ──
const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: SITE.name,
  applicationCategory: "BusinessApplication",
  applicationSubCategory: "Construction Management Software",
  operatingSystem: "Web, Android, iOS (PWA)",
  description:
    "sotyn.ai is an AI construction operating system for Indian EPC, MEP and solar contractors. It connects projects, procurement, site reporting (DPR), BOQ tracking, billing and finance in one platform — so teams reduce delays, protect margins and get paid faster. Built and run inside a live 535+ project EPC company.",
  url: SITE.url,
  inLanguage: "en-IN",
  author: { "@type": "Organization", name: SITE.parentCompany },
  publisher: { "@type": "Organization", name: SITE.parentCompany },
  featureList: [
    "AI project & site intelligence",
    "Daily Progress Reports (DPR)",
    "BOQ vs actual consumption tracking",
    "Procurement, indents & purchase orders",
    "RA billing with GST, TDS & retention",
    "Attendance, payroll & compliance",
    "Weekly performance scorecard",
    "Dedicated Solar EPC division",
  ],
  offers: {
    "@type": "Offer",
    priceCurrency: "INR",
    price: "0",
    description: "Book a free demo. Pricing tailored to your team size.",
  },
  areaServed: { "@type": "Country", name: "India" },
};

const allSchema = [orgSchema, appSchema, ...schema];

// Meta (Facebook) Pixel — built here as a plain string, injected via set:html.
const fbPixel = SITE.metaPixelId
  ? `!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${SITE.metaPixelId}');fbq('track','PageView');`
  : "";
const fbNoscript = SITE.metaPixelId
  ? `<img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=${SITE.metaPixelId}&ev=PageView&noscript=1"/>`
  : "";
---
<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Brand / perf -->
    <meta name="theme-color" content="#163a72" />
    <meta name="author" content={SITE.parentCompany} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Inter Variable Font — optical sizing, 300-900 weight range -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    />

    <!-- Structured data (JSON-LD) -->
    {allSchema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Meta (Facebook) Pixel — for ad → webinar → buy tracking. Set SITE.metaPixelId. -->
    {fbPixel && <script is:inline set:html={fbPixel} />}
    {fbNoscript && <noscript set:html={fbNoscript} />}
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
    <ExitPopup />
    <ScrollAnimations />
  </body>
</html>
