---
// On-brand explanatory diagrams — one per key sales-deck section.
// Each SVG "explains the words" of its section. Palette matches global.css.
// dark diagrams (problem, scorecard) render on section--dark backgrounds.
export interface Props { name: string; }
const { name } = Astro.props;
const F = "Inter, system-ui, -apple-system, sans-serif";
---
<figure class="secdiagram" aria-hidden="true">
{name === "problem" && (
  <svg viewBox="0 0 760 340" role="img" xmlns="http://www.w3.org/2000/svg" style={`font-family:${F}`}>
    <defs>
      <marker id="pArr" markerWidth="9" markerHeight="9" refX="6" refY="4.5" orient="auto">
        <path d="M0 0 L8 4.5 L0 9 Z" fill="#64748b" />
      </marker>
    </defs>
    <!-- three disconnected systems -->
    <g>
      <rect x="34" y="24" width="196" height="60" rx="14" fill="rgba(255,255,255,.06)" stroke="rgba(255,255,255,.18)" />
      <text x="132" y="60" text-anchor="middle" fill="#e2e8f0" font-size="19" font-weight="700">WhatsApp</text>
      <rect x="282" y="24" width="196" height="60" rx="14" fill="rgba(255,255,255,.06)" stroke="rgba(255,255,255,.18)" />
      <text x="380" y="60" text-anchor="middle" fill="#e2e8f0" font-size="19" font-weight="700">Excel</text>
      <rect x="530" y="24" width="196" height="60" rx="14" fill="rgba(255,255,255,.06)" stroke="rgba(255,255,255,.18)" />
      <text x="628" y="60" text-anchor="middle" fill="#e2e8f0" font-size="19" font-weight="700">Memory</text>
      <text x="256" y="61" text-anchor="middle" fill="#60a5fa" font-size="22" font-weight="800">&#8800;</text>
      <text x="504" y="61" text-anchor="middle" fill="#60a5fa" font-size="22" font-weight="800">&#8800;</text>
    </g>
    <!-- converging arrows to YOU -->
    <line x1="132" y1="86" x2="360" y2="168" stroke="#64748b" stroke-width="2" marker-end="url(#pArr)" />
    <line x1="380" y1="86" x2="380" y2="162" stroke="#64748b" stroke-width="2" marker-end="url(#pArr)" />
    <line x1="628" y1="86" x2="400" y2="168" stroke="#64748b" stroke-width="2" marker-end="url(#pArr)" />
    <!-- YOU node = the bottleneck -->
    <circle cx="380" cy="208" r="46" fill="#2563eb" />
    <text x="380" y="203" text-anchor="middle" fill="#fff" font-size="21" font-weight="800">YOU</text>
    <text x="380" y="223" text-anchor="middle" fill="#dbeafe" font-size="12" font-weight="600">the server</text>
    <!-- leaks -->
    <g font-size="13" font-weight="600" fill="#94a3b8">
      <rect x="70" y="292" width="180" height="34" rx="17" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.14)" />
      <circle cx="92" cy="309" r="3.5" fill="#f59e0b" opacity=".8" /><text x="104" y="313">Delayed POs</text>
      <rect x="290" y="292" width="200" height="34" rx="17" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.14)" />
      <circle cx="312" cy="309" r="3.5" fill="#f59e0b" opacity=".8" /><text x="324" y="313">Missed receivables</text>
      <rect x="530" y="292" width="180" height="34" rx="17" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.14)" />
      <circle cx="552" cy="309" r="3.5" fill="#f59e0b" opacity=".8" /><text x="564" y="313">Cost overruns</text>
    </g>
    <line x1="380" y1="254" x2="380" y2="286" stroke="#64748b" stroke-width="2" marker-end="url(#pArr)" />
  </svg>
)}

{name === "options" && (
  <svg viewBox="0 0 760 250" role="img" xmlns="http://www.w3.org/2000/svg" style={`font-family:${F}`}>
    <defs>
      <marker id="oArr" markerWidth="9" markerHeight="9" refX="6" refY="4.5" orient="auto">
        <path d="M0 0 L8 4.5 L0 9 Z" fill="#9ca3af" />
      </marker>
    </defs>
    <g>
      <rect x="30" y="20" width="210" height="62" rx="14" fill="#f3f4f6" stroke="#e5e7eb" />
      <text x="135" y="47" text-anchor="middle" fill="#111827" font-size="17" font-weight="800">A big ERP</text>
      <text x="135" y="67" text-anchor="middle" fill="#6b7280" font-size="12.5" font-weight="600">SAP / Oracle</text>
      <rect x="275" y="20" width="210" height="62" rx="14" fill="#f3f4f6" stroke="#e5e7eb" />
      <text x="380" y="47" text-anchor="middle" fill="#111827" font-size="17" font-weight="800">A stack of apps</text>
      <text x="380" y="67" text-anchor="middle" fill="#6b7280" font-size="12.5" font-weight="600">Tally + Zoho + 5 tools</text>
      <rect x="520" y="20" width="210" height="62" rx="14" fill="#f3f4f6" stroke="#e5e7eb" />
      <text x="625" y="47" text-anchor="middle" fill="#111827" font-size="17" font-weight="800">More managers</text>
      <text x="625" y="67" text-anchor="middle" fill="#6b7280" font-size="12.5" font-weight="600">+ more Excel</text>
    </g>
    <line x1="135" y1="82" x2="360" y2="150" stroke="#9ca3af" stroke-width="2" marker-end="url(#oArr)" />
    <line x1="380" y1="82" x2="380" y2="150" stroke="#9ca3af" stroke-width="2" marker-end="url(#oArr)" />
    <line x1="625" y1="82" x2="400" y2="150" stroke="#9ca3af" stroke-width="2" marker-end="url(#oArr)" />
    <rect x="150" y="162" width="460" height="64" rx="16" fill="#111827" />
    <text x="380" y="190" text-anchor="middle" fill="#fff" font-size="17" font-weight="800">The same gap</text>
    <text x="380" y="211" text-anchor="middle" fill="#cbd5e1" font-size="13" font-weight="600">You’re still the integration between your own software</text>
  </svg>
)}

{name === "scorecard" && (
  <svg viewBox="0 0 760 300" role="img" xmlns="http://www.w3.org/2000/svg" style={`font-family:${F}`}>
    <rect x="16" y="16" width="728" height="268" rx="18" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.12)" />
    <text x="46" y="56" fill="#e2e8f0" font-size="18" font-weight="800">One employee · 6-week score trend</text>
    <!-- current score chip -->
    <rect x="566" y="34" width="150" height="46" rx="12" fill="#2563eb" />
    <text x="588" y="64" fill="#fff" font-size="24" font-weight="900">8.4</text>
    <text x="636" y="58" fill="#dbeafe" font-size="12" font-weight="700">this week</text>
    <text x="636" y="72" fill="#dbeafe" font-size="12" font-weight="700">Reliable</text>
    <!-- band reference lines -->
    <line x1="90" y1="159" x2="700" y2="159" stroke="#3b82f6" stroke-width="1.4" stroke-dasharray="5 5" opacity=".55" />
    <text x="90" y="152" fill="#93c5fd" font-size="11.5" font-weight="700">7+ reliable</text>
    <line x1="90" y1="204" x2="700" y2="204" stroke="#64748b" stroke-width="1.4" stroke-dasharray="5 5" opacity=".7" />
    <text x="90" y="197" fill="#94a3b8" font-size="11.5" font-weight="700">&lt;5 risk</text>
    <!-- trend line W1..W6 -->
    <polyline points="110,204 218,186 326,170 434,154 542,140 650,127" fill="none" stroke="#3b82f6" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
    <g fill="#fff" stroke="#2563eb" stroke-width="2.5">
      <circle cx="110" cy="204" r="5" /><circle cx="218" cy="186" r="5" /><circle cx="326" cy="170" r="5" />
      <circle cx="434" cy="154" r="5" /><circle cx="542" cy="140" r="5" /><circle cx="650" cy="127" r="6.5" />
    </g>
    <g fill="#94a3b8" font-size="12" font-weight="600" text-anchor="middle">
      <text x="110" y="250">W1</text><text x="218" y="250">W2</text><text x="326" y="250">W3</text>
      <text x="434" y="250">W4</text><text x="542" y="250">W5</text><text x="650" y="250">W6</text>
    </g>
    <text x="380" y="277" text-anchor="middle" fill="#e2e8f0" font-size="13.5" font-weight="700">The 6-week trend — not one week — is the truth.</text>
  </svg>
)}

{name === "inside" && (
  <svg viewBox="0 0 760 300" role="img" xmlns="http://www.w3.org/2000/svg" style={`font-family:${F}`}>
    <!-- spokes -->
    <g stroke="#dbeafe" stroke-width="2">
      <line x1="380" y1="150" x2="380" y2="43" /><line x1="380" y1="150" x2="554" y2="70" />
      <line x1="380" y1="150" x2="646" y2="138" /><line x1="380" y1="150" x2="614" y2="215" />
      <line x1="380" y1="150" x2="472" y2="258" /><line x1="380" y1="150" x2="288" y2="258" />
      <line x1="380" y1="150" x2="146" y2="215" /><line x1="380" y1="150" x2="114" y2="138" />
      <line x1="380" y1="150" x2="206" y2="70" />
    </g>
    <!-- nodes -->
    <g font-size="12.5" font-weight="700" fill="#1f2937" text-anchor="middle">
      {[
        {x:380,y:43,t:"Projects"},{x:554,y:70,t:"Site DPRs"},{x:646,y:138,t:"Estimation"},
        {x:614,y:215,t:"Procurement"},{x:472,y:258,t:"Sales ₹"},{x:288,y:258,t:"Finance"},
        {x:146,y:215,t:"Labour"},{x:114,y:138,t:"Scorecard"},{x:206,y:70,t:"Compliance"},
      ].map((n) => (
        <g>
          <rect x={n.x-52} y={n.y-16} width="104" height="32" rx="16" fill="#fff" stroke="#dbeafe" stroke-width="1.5" />
          <text x={n.x} y={n.y+4.5}>{n.t}</text>
        </g>
      ))}
    </g>
    <!-- hub -->
    <circle cx="380" cy="150" r="58" fill="#2563eb" />
    <text x="380" y="145" text-anchor="middle" fill="#fff" font-size="17" font-weight="900">sotyn.ai</text>
    <text x="380" y="166" text-anchor="middle" fill="#dbeafe" font-size="12" font-weight="700">one login</text>
  </svg>
)}

{name === "how" && (
  <svg viewBox="0 0 760 180" role="img" xmlns="http://www.w3.org/2000/svg" style={`font-family:${F}`}>
    <line x1="70" y1="86" x2="690" y2="86" stroke="#e5e7eb" stroke-width="5" stroke-linecap="round" />
    <line x1="70" y1="86" x2="690" y2="86" stroke="#2563eb" stroke-width="5" stroke-linecap="round" opacity=".9" />
    <g>
      {[
        {x:150,n:"1",t:"Audit",d:"Day 1–7"},
        {x:330,n:"2",t:"Configure",d:"Day 8–18"},
        {x:510,n:"3",t:"Train",d:"Day 19–26"},
        {x:660,n:"4",t:"Go live",d:"Day 30"},
      ].map((s) => (
        <g>
          <text x={s.x} y="52" text-anchor="middle" fill="#1f2937" font-size="15.5" font-weight="800">{s.t}</text>
          <circle cx={s.x} cy="86" r="20" fill="#2563eb" stroke="#fff" stroke-width="3" />
          <text x={s.x} y="92" text-anchor="middle" fill="#fff" font-size="16" font-weight="900">{s.n}</text>
          <text x={s.x} y="126" text-anchor="middle" fill="#6b7280" font-size="12.5" font-weight="600">{s.d}</text>
        </g>
      ))}
    </g>
    <rect x="612" y="140" width="96" height="28" rx="14" fill="#111827" />
    <text x="660" y="159" text-anchor="middle" fill="#fff" font-size="13" font-weight="800">30 days</text>
  </svg>
)}

{name === "pilot" && (
  <svg viewBox="0 0 760 210" role="img" xmlns="http://www.w3.org/2000/svg" style={`font-family:${F}`}>
    <defs>
      <marker id="plArr" markerWidth="10" markerHeight="10" refX="6" refY="5" orient="auto">
        <path d="M0 0 L9 5 L0 10 Z" fill="#2563eb" />
      </marker>
    </defs>
    <!-- Day 0 -->
    <rect x="24" y="40" width="230" height="128" rx="16" fill="#f3f4f6" stroke="#e5e7eb" />
    <text x="139" y="72" text-anchor="middle" fill="#111827" font-size="15" font-weight="800">Day 0 · today</text>
    <g>
      <rect x="52" y="92" width="52" height="30" rx="8" fill="#fff" stroke="#d1d5db" />
      <rect x="113" y="92" width="52" height="30" rx="8" fill="#fff" stroke="#d1d5db" />
      <rect x="174" y="92" width="52" height="30" rx="8" fill="#fff" stroke="#d1d5db" />
    </g>
    <text x="139" y="146" text-anchor="middle" fill="#6b7280" font-size="12.5" font-weight="600">WhatsApp · Excel · memory</text>
    <!-- arrow -->
    <line x1="268" y1="104" x2="492" y2="104" stroke="#2563eb" stroke-width="3" marker-end="url(#plArr)" />
    <rect x="316" y="86" width="128" height="34" rx="17" fill="#fff" stroke="#2563eb" stroke-width="1.5" />
    <text x="380" y="108" text-anchor="middle" fill="#1d4ed8" font-size="13.5" font-weight="800">30-DAY PILOT</text>
    <!-- Day 30 -->
    <rect x="506" y="40" width="230" height="128" rx="16" fill="#eff6ff" stroke="#dbeafe" />
    <text x="621" y="72" text-anchor="middle" fill="#1d4ed8" font-size="15" font-weight="800">Day 30 · live</text>
    <rect x="576" y="90" width="90" height="34" rx="9" fill="#2563eb" />
    <text x="621" y="112" text-anchor="middle" fill="#fff" font-size="13" font-weight="800">one system</text>
    <text x="621" y="146" text-anchor="middle" fill="#2563eb" font-size="12.5" font-weight="700">running · reviewed weekly</text>
    <!-- credited ribbon -->
    <rect x="214" y="182" width="332" height="24" rx="12" fill="#111827" />
    <text x="380" y="199" text-anchor="middle" fill="#fff" font-size="12" font-weight="700">Paid — 100% credited when you subscribe annually</text>
  </svg>
)}
</figure>

<style>
  .secdiagram { width: 100%; max-width: 840px; margin: 22px auto 0; }
  .secdiagram svg { width: 100%; height: auto; display: block; }
</style>
