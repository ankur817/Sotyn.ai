---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LeadCapture from "../../components/LeadCapture.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../config/site";

const steps = [
  { n: "1", t: "Build the true cost per item", d: "Material + labour for one unit of the BOQ line — the real, current cost, not last year's." },
  { n: "2", t: "Load site overhead", d: "Supervision, establishment, rentals, tools — as a % on direct cost. Skip this and margin vanishes on site." },
  { n: "3", t: "Set the floor (break-even)", d: "Your fully-loaded cost is the rate below which you lose money. Never bid a line below it knowingly." },
  { n: "4", t: "Set the target rate", d: "The rate that delivers your target net margin, worked back from cost — not cost plus a markup." },
  { n: "5", t: "Compare the tender rate", d: "Healthy, thin, or loss-making? Do it line by line — a profitable-looking tender often hides loss-making items." },
  { n: "6", t: "Decide: bid, load, or walk", d: "Load rates where you can, protect the floor everywhere, and know your blended margin before you submit." },
];

const schema = [{
  "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Resources", item: `${SITE.url}/resources` },
    { "@type": "ListItem", position: 3, name: "Tender Rate Analysis Framework", item: `${SITE.url}/resources/tender-rate-analysis` },
  ],
}];
---
<BaseLayout
  title="Tender Rate Analysis Framework for Contractors (+ free analyzer) | sotyn.ai India"
  description="A free framework and live analyzer to judge tender rates for Indian EPC contractors: build true cost, load overhead, find your break-even and target rate, and see if a rate is healthy, thin or loss-making. No sign-up."
  path="/resources/tender-rate-analysis"
  schema={schema}
>
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="container"><a href="/">Home</a> <span aria-hidden="true">/</span> <a href="/resources">Resources</a> <span aria-hidden="true">/</span> <span>Tender Rate Analysis</span></div>
  </nav>

  <section class="section" style="padding-bottom:14px">
    <div class="container container--narrow text-center">
      <span class="eyebrow">Free framework + live analyzer</span>
      <h1>Is that tender rate actually profitable?</h1>
      <p class="lead" style="margin-inline:auto">Contractors win tenders and lose money on them — because a rate that looks fine hides loss-making lines. This framework and analyzer tell you, per item, whether a rate is healthy, thin or below your floor.</p>
    </div>
  </section>

  <section class="section" style="padding-top:8px" id="tool">
    <div class="container tra">
      <div class="tra__inputs">
        <h2 class="tra__h">Analyze one BOQ line</h2>
        <label>Tender / quoted rate (₹ per unit)<input type="number" id="tr_rate" value="1200" min="0" /></label>
        <div class="tra__two">
          <label>Material cost (₹/unit)<input type="number" id="tr_mat" value="620" min="0" /></label>
          <label>Labour cost (₹/unit)<input type="number" id="tr_lab" value="280" min="0" /></label>
        </div>
        <div class="tra__two">
          <label>Site overhead %<input type="number" id="tr_oh" value="12" min="0" /></label>
          <label>Target net margin %<input type="number" id="tr_mg" value="15" min="0" /></label>
        </div>
      </div>

      <aside class="tra__result" aria-live="polite">
        <div class="tra__verdict" id="tr_verdict">—</div>
        <div class="tra__rows">
          <div><span>Margin at this rate</span><b id="tr_margin">—</b></div>
          <div><span>Break-even (floor) rate</span><b id="tr_break">—</b></div>
          <div><span>Rate for target margin</span><b id="tr_target">—</b></div>
        </div>
        <div class="tra__actions">
          <button type="button" class="btn btn--ghost" id="trPrint"><Icon name="download" size={17} /> Save analysis (PDF)</button>
          <a class="btn btn--primary" href="/tools/quote-margin">Quote margin calculator →</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">The framework</span>
        <h2>Six steps to a rate you can trust.</h2>
      </div>
      <div class="tra__steps">
        {steps.map((s) => (
          <div class="tra__step"><div class="tra__n">{s.n}</div><div><h3>{s.t}</h3><p>{s.d}</p></div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container tra__ai">
      <div>
        <span class="eyebrow">Do it across the whole BOQ — with AI</span>
        <h2 style="color:#fff">One line by hand is easy. 800 lines before the deadline isn't.</h2>
        <p class="lead" style="color:#cbd5e1">sotyn.ai's <strong>AI Auto-Quotation</strong> applies this framework to an entire tender: upload the client BOQ, it matches your own rate masters and returns a priced quote with margin on every line — and flags the loss-making ones before you submit. <span class="soon">Coming soon</span></p>
        <div class="btn-row" style="margin-top:20px">
          <a href="/demo" class="btn btn--white btn--lg">See the roadmap in a demo</a>
        </div>
      </div>
      <div class="tra__lead">
        <LeadCapture
          source="tender-rate-framework"
          magnet="Tender Rate Analysis Framework"
          heading="Get the framework + a BOQ rate sheet"
          sub="We'll send the full framework and let you know when AI Auto-Quotation opens for early access."
          cta="Send it to me"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .crumb { border-bottom: 1px solid var(--line); background: var(--bg-alt); }
  .crumb .container { padding: 12px 22px; font-size: .86rem; color: var(--muted); }
  .crumb a { color: var(--brand-700); font-weight: 600; }
  .crumb span[aria-hidden] { margin: 0 8px; color: var(--graphite-300); }

  .tra { display: grid; grid-template-columns: 1.15fr 1fr; gap: 26px; align-items: start; max-width: 960px; margin-inline: auto; }
  .tra__inputs { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 24px; box-shadow: var(--shadow-sm); display: grid; gap: 14px; }
  .tra__h { font-size: 1.05rem; margin: 0 0 2px; }
  .tra__two { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .tra label { display: grid; gap: 6px; font-weight: 600; font-size: .84rem; color: var(--ink); }
  .tra input { font-family: inherit; font-size: 1rem; padding: 11px 13px; border: 1.5px solid var(--line); border-radius: 10px; background: #fff; color: var(--ink); width: 100%; font-variant-numeric: tabular-nums; }
  .tra input:focus { border-color: var(--brand-500); outline: none; box-shadow: 0 0 0 3px rgba(41,151,255,.18); }

  .tra__result { position: sticky; top: 92px; background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 22px; box-shadow: var(--shadow-sm); }
  .tra__verdict { text-align: center; font-weight: 800; font-size: 1.05rem; padding: 12px; border-radius: 12px; margin-bottom: 16px; }
  .tra__verdict.g { background: var(--ok-bg, #e6f5ec); color: var(--ok, #1a8f52); }
  .tra__verdict.a { background: var(--warn-bg, #fbf1de); color: var(--warn, #b9791a); }
  .tra__verdict.r { background: var(--crit-bg, #fbe8eb); color: var(--crit, #c23a4b); }
  .tra__rows { display: grid; gap: 11px; margin-bottom: 16px; }
  .tra__rows > div { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; border-bottom: 1px solid var(--line-2, #eef2f7); padding-bottom: 9px; }
  .tra__rows span { font-size: .84rem; color: var(--muted); font-weight: 600; }
  .tra__rows b { font-size: 1.1rem; font-weight: 800; color: var(--ink); font-variant-numeric: tabular-nums; }
  .tra__actions { display: grid; gap: 9px; }
  .tra__actions .btn { width: 100%; }

  .tra__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .tra__step { display: flex; gap: 14px; background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 20px; box-shadow: var(--shadow-sm); }
  .tra__n { width: 36px; height: 36px; border-radius: 10px; background: var(--brand-600); color: #fff; font-weight: 900; display: grid; place-items: center; flex: none; }
  .tra__step h3 { font-size: 1rem; margin: 2px 0 5px; }
  .tra__step p { font-size: .9rem; color: var(--body); margin: 0; }
  @media (max-width: 820px) { .tra { grid-template-columns: 1fr; } .tra__result { position: static; } .tra__steps { grid-template-columns: 1fr; } }

  .tra__ai { display: grid; grid-template-columns: 1.15fr 1fr; gap: 40px; align-items: center; }
  .soon { display: inline-block; margin-left: 6px; padding: 3px 10px; border-radius: 999px; background: rgba(255,255,255,.12); color: #fff; font-size: .68rem; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; vertical-align: middle; }
  @media (max-width: 860px) { .tra__ai { grid-template-columns: 1fr; gap: 28px; } }

  @media print { :global(header), :global(footer), :global(.announce), :global(.crumb), .tra__actions, .section--dark { display: none !important; } .tra { grid-template-columns: 1fr; } .tra__result { position: static; } }
</style>

<script is:inline>
  (function () {
    function g(id) { var el = document.getElementById(id); return el ? (parseFloat(el.value) || 0) : 0; }
    function inr(n) {
      var neg = n < 0; n = Math.abs(n);
      var o = "₹" + Math.round(n).toLocaleString("en-IN");
      return (neg ? "−" : "") + o;
    }
    var verdict = document.getElementById("tr_verdict"), ctx = document.getElementById("leadContext");
    function update() {
      var rate = g("tr_rate"), mat = g("tr_mat"), lab = g("tr_lab"), oh = g("tr_oh"), mg = g("tr_mg");
      var direct = mat + lab;
      var cost = direct * (1 + oh / 100);
      var required = mg < 100 ? cost / (1 - mg / 100) : cost;
      var margin = rate > 0 ? ((rate - cost) / rate) * 100 : 0;
      document.getElementById("tr_margin").textContent = isFinite(margin) ? margin.toFixed(1) + "%" : "—";
      document.getElementById("tr_break").textContent = inr(cost);
      document.getElementById("tr_target").textContent = inr(required);
      var status, label;
      if (rate < cost) { status = "r"; label = "● Loss-making — below your cost floor"; }
      else if (rate < required) { status = "a"; label = "● Thin — below your target margin"; }
      else { status = "g"; label = "● Healthy — meets your target margin"; }
      verdict.className = "tra__verdict " + status;
      verdict.textContent = label;
      if (ctx) ctx.value = "Tender rate " + inr(rate) + " → margin " + margin.toFixed(1) + "% (" + label.replace("● ", "") + "); break-even " + inr(cost);
    }
    ["tr_rate", "tr_mat", "tr_lab", "tr_oh", "tr_mg"].forEach(function (id) { var el = document.getElementById(id); if (el) el.addEventListener("input", update); });
    document.getElementById("trPrint").addEventListener("click", function () { window.print(); });
    update();
  })();
</script>
