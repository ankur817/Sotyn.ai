---
// Monochrome line icons. Inherit color via currentColor so they only ever
// render in the 3-colour palette (graphite or royal blue, set by the parent).
export interface Props { name: string; size?: number; class?: string; }
const { name, size = 24, class: cls = "" } = Astro.props;

const stroke =
  'fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"';

const paths: Record<string, string> = {
  // 4 money questions
  "trending-down": `<g ${stroke}><polyline points="3 7 10 14 14 10 21 17"/><polyline points="21 12 21 17 16 17"/></g>`,
  droplet: `<path ${stroke} d="M12 3.6c3 3.9 5.5 6.8 5.5 9.6a5.5 5.5 0 0 1-11 0c0-2.8 2.5-5.7 5.5-9.6Z"/>`,
  alert: `<g ${stroke}><path d="M12 4 21 19.5H3L12 4Z"/><line x1="12" y1="10" x2="12" y2="13.5"/></g><circle cx="12" cy="16.4" r="1" fill="currentColor"/>`,
  "trending-up": `<g ${stroke}><polyline points="3 17 10 10 14 14 21 7"/><polyline points="16 7 21 7 21 12"/></g>`,
  // 6 module groups
  target: `<g ${stroke}><circle cx="12" cy="12" r="8.2"/><circle cx="12" cy="12" r="4.2"/></g><circle cx="12" cy="12" r="1.4" fill="currentColor"/>`,
  wallet: `<g ${stroke}><rect x="3" y="6" width="18" height="13" rx="2.5"/><path d="M16 11.5h5v3h-5a1.5 1.5 0 0 1 0-3Z"/><path d="M3 8.5h13"/></g>`,
  box: `<g ${stroke}><path d="M21 8.2 12 3.4 3 8.2v7.6l9 4.8 9-4.8Z"/><path d="M3 8.2l9 4.8 9-4.8"/><line x1="12" y1="13" x2="12" y2="20.6"/></g>`,
  building: `<g ${stroke}><path d="M4 21V6.5L13 3v18"/><path d="M13 9l7 2.5V21"/><line x1="3" y1="21" x2="21.5" y2="21"/><line x1="7" y1="8" x2="7.01" y2="8"/><line x1="7" y1="12" x2="7.01" y2="12"/><line x1="7" y1="16" x2="7.01" y2="16"/><line x1="16.5" y1="15" x2="16.51" y2="15"/></g>`,
  users: `<g ${stroke}><circle cx="9" cy="8" r="3.3"/><path d="M3.5 19.5a5.5 5.5 0 0 1 11 0"/><path d="M16.2 5.2a3.3 3.3 0 0 1 0 6"/><path d="M17.2 14.4a5.5 5.5 0 0 1 3.3 5.1"/></g>`,
  gauge: `<g ${stroke}><path d="M4 16a8 8 0 0 1 16 0"/><line x1="12" y1="16" x2="15.5" y2="11.5"/></g><circle cx="12" cy="16" r="1.3" fill="currentColor"/>`,
  // about values
  hardhat: `<g ${stroke}><path d="M3.5 17a8.5 8.5 0 0 1 17 0"/><line x1="2.5" y1="17" x2="21.5" y2="17"/><path d="M9.5 9V6.6A2 2 0 0 1 12 4.7"/><path d="M14.5 9.4V8a2 2 0 0 0-1.2-1.8"/></g>`,
  chat: `<path ${stroke} d="M21 14.5a2 2 0 0 1-2 2H8.5L4 20.5V6a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2Z"/>`,
  refresh: `<g ${stroke}><path d="M20 12a8 8 0 1 1-2.3-5.6"/><polyline points="20 4 20 9 15 9"/></g>`,
  // misc
  check: `<polyline ${stroke} points="4 12 9 17 20 6"/>`,
  shield: `<g ${stroke}><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-3Z"/><polyline points="8.8 12 11 14.2 15.2 9.8"/></g>`,
  pin: `<g ${stroke}><path d="M12 21s7-6 7-11a7 7 0 0 0-14 0c0 5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></g>`,
  phone: `<path ${stroke} d="M6 3h3l1.8 4.6-2.3 1.4a11 11 0 0 0 5.5 5.5l1.4-2.3L21 16v3a2 2 0 0 1-2 2A16 16 0 0 1 4 6a2 2 0 0 1 2-3Z"/>`,
  "arrow-right": `<g ${stroke}><line x1="4" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></g>`,
  bolt: `<path ${stroke} d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/>`,
  layers: `<g ${stroke}><path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="M3 13l9 5 9-5"/></g>`,
  download: `<g ${stroke}><path d="M12 3v12"/><polyline points="7 11 12 16 17 11"/><path d="M5 20h14"/></g>`,
  lock: `<g ${stroke}><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></g>`,
  book: `<g ${stroke}><path d="M6 3h12a1 1 0 0 1 1 1v15H7a2 2 0 0 0-2 2V5a2 2 0 0 1 1-2Z"/><path d="M19 19H7a2 2 0 0 0-2 2"/></g>`,
  whatsapp: `<path fill="currentColor" d="M16 3C9 3 3.5 8.5 3.5 15.5c0 2.4.7 4.7 1.9 6.7L3 29l7-1.8c1.9 1 4 1.6 6.1 1.6 7 0 12.5-5.5 12.5-12.5S23 3 16 3zm0 22.6c-1.9 0-3.7-.5-5.3-1.5l-.4-.2-4.2 1.1 1.1-4-.2-.4c-1.1-1.7-1.6-3.6-1.6-5.6C5.2 9.6 10 4.9 16 4.9s10.8 4.7 10.8 10.6S22 25.6 16 25.6zm6.1-7.9c-.3-.2-1.9-1-2.2-1-.3-.1-.5-.2-.8.2s-.9 1-1 1.2c-.2.2-.4.2-.7.1s-1.4-.5-2.7-1.7c-1-.9-1.6-2-1.8-2.3s0-.5.2-.7l.5-.6c.2-.2.2-.3.3-.5s.1-.4 0-.6-.8-1.9-1-2.6c-.3-.7-.5-.6-.8-.6h-.7c-.2 0-.6.1-.9.4s-1.2 1.2-1.2 2.9 1.2 3.4 1.4 3.6c.2.2 2.5 3.8 6 5.3.8.4 1.5.6 2 .7.8.3 1.6.2 2.2.1.7-.1 1.9-.8 2.2-1.5.3-.8.3-1.4.2-1.5-.1-.2-.3-.3-.6-.4z"/>`,
};

const inner = paths[name] ?? "";
---
<svg
  class={`ico ${cls}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  role="img"
  aria-hidden="true"
  set:html={inner}
></svg>
