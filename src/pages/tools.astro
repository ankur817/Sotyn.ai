---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTABand from "../components/CTABand.astro";
import Icon from "../components/Icon.astro";
import Calculator from "../components/Calculator.astro";
import CalcEngine from "../components/CalcEngine.astro";
import { calculators } from "../config/calculators";
import { SITE } from "../config/site";

const schema = [{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Free calculators", item: `${SITE.url}/tools` },
  ],
}];
---
<BaseLayout
  title="10 Free Calculators for Construction & EPC Contractors — margin, cash, BOQ, GST, RA bill | sotyn.ai"
  description="10 free calculators for Indian construction & EPC contractors: quote margin, profit leak, cash stuck, material wastage, labour leak, delay cost, retention, GST, RA bill net-payable and ROI. No sign-up — instant answers on your own numbers."
  path="/tools"
  schema={schema}
>
  <section class="section" style="padding-bottom:14px">
    <div class="container container--narrow text-center">
      <span class="eyebrow">10 free calculators · no sign-up</span>
      <h1>Find your money leaks in 30 seconds.</h1>
      <p class="lead" style="margin-inline:auto">
        Ten free calculators for Indian EPC &amp; construction contractors — margin, cash, material,
        labour, delays, retention, GST, RA bills and ROI. Punch in your numbers, get the answer instantly,
        and WhatsApp yourself the result.
      </p>
    </div>
    <div class="container">
      <nav class="jump" aria-label="Jump to a calculator">
        {calculators.map((c) => <a href={`#${c.slug}`} class="jump__pill"><Icon name={c.icon} size={15} /> {c.short}</a>)}
      </nav>
    </div>
  </section>

  <section class="section" id="tools" style="padding-top:6px">
    <div class="container tools" data-wa={SITE.whatsapp}>
      {calculators.map((c) => <Calculator calc={c} detailLink={`/tools/${c.slug}`} />)}
    </div>
  </section>

  <CTABand
    title="Want this on your actual numbers, live?"
    text="These are back-of-envelope estimates. In a 20-minute demo we open sotyn.ai on your own trades and project sizes — real margin, real cash, real site status — and show you exactly where the money is going."
  />
  <CalcEngine />
</BaseLayout>

<style>
  .jump { display: flex; flex-wrap: wrap; gap: 9px; justify-content: center; max-width: 960px; margin: 26px auto 0; }
  .jump__pill { display: inline-flex; align-items: center; gap: 6px; font-size: .84rem; font-weight: 600; color: var(--brand-700); background: var(--brand-50); border: 1px solid var(--brand-100); padding: 7px 13px; border-radius: 999px; transition: .18s; }
  .jump__pill:hover { background: var(--brand-100); text-decoration: none; transform: translateY(-1px); }
  .jump__pill :global(.ico) { color: var(--brand-600); }
  .tools { display: grid; grid-template-columns: repeat(auto-fit, minmax(370px, 1fr)); gap: 20px; max-width: 1000px; margin-inline: auto; }
  @media (max-width: 520px) { .tools { grid-template-columns: 1fr; } }
</style>
