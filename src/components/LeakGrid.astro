---
import Icon from "./Icon.astro";

const leaks = [
  { icon: "book", title: "Quoting & Estimation", desc: "Underbidding just to win, ignoring hidden costs, and delayed tender submissions." },
  { icon: "box", title: "Procurement", desc: "Over-ordering materials, missing bulk discounts, and untracked site deliveries." },
  { icon: "users", title: "Labour Management", desc: "Ghost workers on the muster roll, idle time, and unverified overtime payouts." },
  { icon: "hardhat", title: "Site Execution", desc: "Expensive rework, unaccounted material wastage, and blind spots in daily progress." },
  { icon: "layers", title: "Billing & Invoicing", desc: "Unbilled project milestones, disputed RA bills, and missing documentation." },
  { icon: "wallet", title: "Cash Collection", desc: "Capital stuck in retention, forgotten payment follow-ups, and severe cash flow blocks." }
];
---

<div class="leaks">
  {leaks.map(l => (
    <div class="leak-card">
      <div class="leak-card__ic"><Icon name={l.icon} size={28} /></div>
      <h3>{l.title}</h3>
      <p>{l.desc}</p>
    </div>
  ))}
</div>

<style>
  .leaks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 48px;
    text-align: left;
    width: 100%;
  }
  @media (max-width: 900px) {
    .leaks { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }
  @media (max-width: 600px) {
    .leaks { grid-template-columns: 1fr; }
  }
  .leak-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 32px 28px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
    display: flex;
    flex-direction: column;
  }
  .leak-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-md);
    border-color: var(--brand-400);
  }
  .leak-card__ic {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-sm);
    background: var(--bg-tint);
    color: var(--brand-600);
    margin-bottom: 24px;
  }
  .leak-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--ink);
  }
  .leak-card p {
    font-size: 0.95rem;
    color: var(--body);
    line-height: 1.6;
    margin: 0;
  }
</style>
